{
  "name": "@blankparticle/www",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "wrangler types",
    "dev": "vite dev --host",
    "build": "vite build",
    "preview": "pnpm run build && wrangler dev",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "wrangler deploy",
    "format": "prettier --write .",
    "lint": "prettier --check . && oxlint"
  },
  "devDependencies": {
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/karla": "^5.2.8",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.4",
    "@tailwindcss/vite": "4.3.2",
    "@takumi-rs/image-response": "^1.8.7",
    "@types/node": "^26.1.0",
    "eslint-plugin-svelte": "^3.20.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prettier-plugin-tailwindcss-canonical-classes": "^0.1.5",
    "react": "^19.2.7",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "tailwindcss": "4.3.2",
    "tailwindcss-spring": "^1.0.1",
    "vite": "8.1.3",
    "wrangler": "^4.107.0"
  },
  "packageManager": "pnpm@11.8.0"
}
